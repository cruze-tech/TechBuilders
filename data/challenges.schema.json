{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Tech Builders Challenge Schema",
    "type": "object",
    "required": ["schemaVersion", "challenges"],
    "properties": {
        "schemaVersion": {
            "type": "number",
            "minimum": 1
        },
        "challenges": {
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "object",
                "required": ["id", "title", "description", "passScore", "objectives"],
                "properties": {
                    "id": { "type": "string" },
                    "title": { "type": "string" },
                    "description": { "type": "string" },
                    "passScore": { "type": "number", "minimum": 1, "maximum": 100 },
                    "objectives": {
                        "type": "array",
                        "minItems": 1,
                        "items": {
                            "type": "object",
                            "required": ["id", "type", "text", "weight"],
                            "properties": {
                                "id": { "type": "string" },
                                "type": {
                                    "type": "string",
                                    "enum": [
                                        "positive_energy",
                                        "component_presence",
                                        "powered_component",
                                        "component_count_range"
                                    ]
                                },
                                "text": { "type": "string" },
                                "weight": { "type": "number", "minimum": 0, "maximum": 100 },
                                "componentType": { "type": "string" },
                                "minCount": { "type": "number", "minimum": 1 },
                                "threshold": { "type": "number" },
                                "min": { "type": "number", "minimum": 0 },
                                "max": { "type": "number", "minimum": 0 }
                            }
                        }
                    }
                }
            }
        }
    }
}
